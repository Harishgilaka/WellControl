<Window x:Class="WOCS.UI.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WOCS.UI.Views"
        Title="Well Operations Control System"
        WindowState="Maximized">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Body -->
            <RowDefinition Height="40"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <ContentControl Grid.Row="0" Content="{Binding HeaderViewContent}"/>

        <!-- Body (Navigation Host) -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentView}" />

        <!-- Footer -->
        <ContentControl Grid.Row="2" Content="{Binding FooterViewContent}"/>


    </Grid>
</Window>
